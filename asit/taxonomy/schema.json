{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sushildwivedi-tech/ai-governance-toolkit/asit/taxonomy/schema.json",
  "title": "Agentic SDLC Incident Taxonomy (ASIT)",
  "description": "Schema for taxonomy.yaml, the single source of truth for the ASIT failure-mode taxonomy.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "updated", "blast_radius_rubric", "categories"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Semantic version of the taxonomy release.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "updated": {
      "type": "string",
      "description": "ISO-8601 date the taxonomy was last changed.",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "blast_radius_rubric": {
      "type": "object",
      "description": "Explicit 1-5 scoring rubric; every blast_radius value must be justified by one of these bands.",
      "additionalProperties": false,
      "required": ["1", "2", "3", "4", "5"],
      "properties": {
        "1": { "type": "string", "minLength": 1 },
        "2": { "type": "string", "minLength": 1 },
        "3": { "type": "string", "minLength": 1 },
        "4": { "type": "string", "minLength": 1 },
        "5": { "type": "string", "minLength": 1 }
      }
    },
    "categories": {
      "type": "array",
      "items": { "$ref": "#/$defs/category" }
    }
  },
  "$defs": {
    "asit_id": {
      "type": "string",
      "pattern": "^ASIT-(PLAN|DESIGN|BUILD|TEST|REL|OPS|FOUND)-[0-9]{2}$"
    },
    "control_id": {
      "type": "string",
      "pattern": "^CTL-[0-9]{2}$"
    },
    "incident_id": {
      "type": "string",
      "pattern": "^INC-[0-9]{4}$"
    },
    "category": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "definition",
        "causal_locus",
        "lifecycle_stage",
        "detection_point",
        "blast_radius",
        "preconditions",
        "mitigating_controls",
        "related",
        "external_mappings",
        "evidence_status",
        "incident_refs",
        "status"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/asit_id" },
        "name": {
          "type": "string",
          "description": "Short noun phrase.",
          "minLength": 1,
          "maxLength": 80
        },
        "definition": {
          "type": "string",
          "description": "1-2 sentences, testable: a reader of an incident report should be able to decide yes/no.",
          "minLength": 1
        },
        "causal_locus": {
          "type": "string",
          "enum": [
            "model_error",
            "injected_instruction",
            "overbroad_permission",
            "tool_misuse",
            "supply_chain",
            "oversight_failure",
            "context_corruption",
            "identity_gap"
          ]
        },
        "lifecycle_stage": {
          "type": "string",
          "enum": ["PLAN", "DESIGN", "BUILD", "TEST", "REL", "OPS", "FOUND"]
        },
        "detection_point": {
          "type": "string",
          "enum": [
            "pre_execution",
            "pre_commit",
            "ci",
            "human_review",
            "runtime",
            "post_incident",
            "undetected"
          ]
        },
        "blast_radius": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "preconditions": {
          "type": "array",
          "description": "What must be true for this failure to be possible.",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "mitigating_controls": {
          "type": "array",
          "description": "Control IDs from controls.yaml. May be empty; an empty list is a surfaced coverage gap.",
          "items": { "$ref": "#/$defs/control_id" },
          "uniqueItems": true
        },
        "related": {
          "type": "array",
          "description": "Other ASIT category IDs.",
          "items": { "$ref": "#/$defs/asit_id" },
          "uniqueItems": true
        },
        "external_mappings": {
          "type": "object",
          "additionalProperties": false,
          "description": "Only populate where a genuine correspondence exists; do not force mappings.",
          "properties": {
            "owasp_llm": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            "mitre_atlas": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            "cwe": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            "vaiss": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            }
          }
        },
        "evidence_status": {
          "type": "string",
          "enum": ["documented", "reported_anecdotally", "anticipated"]
        },
        "incident_refs": {
          "type": "array",
          "description": "IDs into incidents.yaml. Must be empty when evidence_status is 'anticipated'.",
          "items": { "$ref": "#/$defs/incident_id" },
          "uniqueItems": true
        },
        "status": {
          "type": "string",
          "enum": ["active", "deprecated"]
        },
        "deprecated_by": {
          "$ref": "#/$defs/asit_id",
          "description": "If status is deprecated, the ASIT id that supersedes this one (optional)."
        },
        "notes": {
          "type": "string",
          "description": "Optional free-text maintainer notes."
        }
      }
    }
  }
}
